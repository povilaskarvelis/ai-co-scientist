{
  "eval_set_id": "comprehensive_drug_discovery",
  "name": "Comprehensive Drug Discovery Workflow",
  "description": "End-to-end test of the drug target discovery workflow with multi-turn conversations",
  "eval_cases": [
    {
      "eval_id": "full_workflow_alzheimers",
      "conversation": [
        {
          "invocation_id": "inv-alz-001",
          "user_content": {
            "parts": [{"text": "I'm researching Alzheimer's disease. What are the top drug targets?"}],
            "role": "user"
          },
          "final_response": {
            "parts": [{"text": "For Alzheimer's disease, the top drug targets based on genetic and clinical evidence include: APP (Amyloid Precursor Protein), APOE (Apolipoprotein E), PSEN1 (Presenilin 1), MAPT (Tau), and BACE1 (Beta-secretase 1). These targets are strongly associated with disease pathology."}],
            "role": "model"
          },
          "intermediate_data": {
            "tool_uses": [
              {
                "name": "search_diseases",
                "args": {"query": "Alzheimer"}
              },
              {
                "name": "search_disease_targets",
                "args": {"diseaseId": "MONDO_0004975"}
              }
            ],
            "intermediate_responses": []
          }
        },
        {
          "invocation_id": "inv-alz-002",
          "user_content": {
            "parts": [{"text": "Tell me more about BACE1 - is it a good drug target?"}],
            "role": "user"
          },
          "final_response": {
            "parts": [{"text": "BACE1 has been extensively studied as an Alzheimer's target. While it's druggable as a protease, multiple BACE1 inhibitor clinical trials have failed, including verubecestat by Merck. The failures suggest that reducing amyloid-beta alone may not be sufficient, or that intervention needs to happen earlier in disease progression."}],
            "role": "model"
          },
          "intermediate_data": {
            "tool_uses": [
              {
                "name": "search_targets",
                "args": {"query": "BACE1"}
              },
              {
                "name": "check_druggability",
                "args": {"targetId": "ENSG00000186318"}
              },
              {
                "name": "get_target_drugs",
                "args": {"targetId": "ENSG00000186318"}
              },
              {
                "name": "search_clinical_trials",
                "args": {"query": "BACE1 inhibitor Alzheimer"}
              }
            ],
            "intermediate_responses": []
          }
        }
      ],
      "session_input": {
        "app_name": "co_scientist",
        "user_id": "researcher",
        "state": {}
      }
    },
    {
      "eval_id": "quick_druggability_check",
      "conversation": [
        {
          "invocation_id": "inv-drug-001",
          "user_content": {
            "parts": [{"text": "Is TNF druggable? What drugs target it?"}],
            "role": "user"
          },
          "final_response": {
            "parts": [{"text": "TNF (Tumor Necrosis Factor) is highly druggable. Multiple approved biologics target TNF, including adalimumab (Humira), infliximab (Remicade), and etanercept (Enbrel). These are widely used for inflammatory conditions like rheumatoid arthritis and Crohn's disease."}],
            "role": "model"
          },
          "intermediate_data": {
            "tool_uses": [
              {
                "name": "search_targets",
                "args": {"query": "TNF"}
              },
              {
                "name": "check_druggability",
                "args": {"targetId": "ENSG00000232810"}
              },
              {
                "name": "get_target_drugs",
                "args": {"targetId": "ENSG00000232810"}
              }
            ],
            "intermediate_responses": []
          }
        }
      ],
      "session_input": {
        "app_name": "co_scientist",
        "user_id": "researcher",
        "state": {}
      }
    },
    {
      "eval_id": "literature_deep_dive",
      "conversation": [
        {
          "invocation_id": "inv-lit-001",
          "user_content": {
            "parts": [{"text": "Find papers on GLP-1 receptor agonists for obesity treatment"}],
            "role": "user"
          },
          "final_response": {
            "parts": [{"text": "I found several recent papers on GLP-1 receptor agonists for obesity. Key publications discuss semaglutide (Ozempic/Wegovy) and tirzepatide, which have shown significant weight loss in clinical trials. The research covers mechanisms of action, clinical efficacy, and safety profiles."}],
            "role": "model"
          },
          "intermediate_data": {
            "tool_uses": [
              {
                "name": "search_pubmed",
                "args": {"query": "GLP-1 receptor agonist obesity treatment"}
              }
            ],
            "intermediate_responses": []
          }
        }
      ],
      "session_input": {
        "app_name": "co_scientist",
        "user_id": "researcher",
        "state": {}
      }
    }
  ]
}

      "eval_id": "chronosbio_temporal_ordering",
      "conversation": [
        {
          "invocation_id": "inv-stress-001",
          "user_content": {
            "parts": [{"text": "Infer a plausible temporal ordering of KRAS-driven signaling events from static phosphoproteomics evidence and explain uncertainty."}],
            "role": "user"
          },
          "final_response": {
            "parts": [{"text": "Response provides explicit assumptions, a stepwise temporal hypothesis, uncertainty bounds, supporting evidence references, limitations, and next validation experiments."}],
            "role": "model"
          },
          "intermediate_data": {
            "tool_uses": [
              {
                "name": "search_reactome_pathways",
                "args": {"query": "KRAS signaling phosphoproteomics", "limit": 8}
              },
              {
                "name": "get_string_interactions",
                "args": {"identifier": "KRAS", "requiredScore": 700, "limit": 12}
              },
              {
                "name": "search_pubmed_advanced",
                "args": {"query": "KRAS phosphoproteomics temporal signaling", "retmax": 8, "sort": "date"}
              }
            ],
            "intermediate_responses": []
          }
        }
      ],
      "session_input": {
        "app_name": "co_scientist",
        "user_id": "researcher",
        "state": {}
      }

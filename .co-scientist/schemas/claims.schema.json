{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ai-co-scientist:schemas:claims:v1",
  "title": "AI Co-Scientist Claim Record",
  "type": "object",
  "required": [
    "schema",
    "id",
    "claim",
    "supporting_evidence",
    "source_identifiers",
    "confidence",
    "status"
  ],
  "properties": {
    "schema": {
      "const": "co_scientist.claim.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^C[0-9]+$"
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "supporting_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^E[0-9]+$"
      }
    },
    "source_identifiers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "moderate",
        "low",
        "mixed",
        "unknown"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "supported",
        "mixed",
        "unsupported",
        "needs_review"
      ]
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}

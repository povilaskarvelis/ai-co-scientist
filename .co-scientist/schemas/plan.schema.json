{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ai-co-scientist:schemas:plan:v1",
  "title": "AI Co-Scientist Investigation Plan",
  "type": "object",
  "required": [
    "schema",
    "objective",
    "success_criteria",
    "steps"
  ],
  "properties": {
    "schema": {
      "const": "co_scientist.plan.v1"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "executing",
        "synthesized",
        "blocked"
      ]
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "goal",
          "tool_hint",
          "domains",
          "completion_condition",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^S[0-9]+$"
          },
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "tool_hint": {
            "type": "string",
            "minLength": 1
          },
          "source_notes": {
            "type": "string"
          },
          "domains": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "completion_condition": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "completed",
              "blocked",
              "skipped"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
